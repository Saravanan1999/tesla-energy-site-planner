# Copy this file to .env and adjust as needed.
# .env is gitignored — never commit real env files.

# Controls which backend the frontend targets.
# Values: local | prod
# Default (when unset): local  →  http://localhost:8080
#                       prod   →  https://tesla-energy-site-planner.onrender.com
VITE_APP_ENV=local

# Optional: override the backend URL directly, ignoring VITE_APP_ENV.
# VITE_API_URL=http://my-custom-backend:8080
